  "per_symbol_overrides": {
    "300274.SZ": {
      "symbol_specific_notes": "300274极易深幅洗盘，ASY+3H/OB_up必判UTAD看空，AS+3L/OS_down必判空头加速看空。破位与极端枯竭冲突时，枯竭陷阱优先，严禁免疫。"
    },
    "002050.SZ": {
      "symbol_specific_notes": "002050.SZ 趋势延续性强，OB_up/3H多为中继蓄力，需右侧SOW确认方可看空。"
    },
    "002384.SZ": {
      "symbol_specific_notes": "002384.SZ高波动成长股，支撑阻力需放大容错；低位破位多为震仓，勿死守破位逻辑。"
    },
    "000776.SZ": {
      "symbol_specific_notes": "金融股带量破位多为真突破，OB_up视为加速；低位极端枯竭后的假破需警惕Spring，收回支撑即可反转。"
    },
    "002475.SZ": {
      "symbol_specific_notes": "002475高波动成长股：深幅击穿支撑若无供应跟随常为Spring洗盘；上升趋势中OB_up常钝化作中继，无SOW严禁高置信度猜顶。"
    },
    "000858.SZ": {
      "symbol_specific_notes": "000858.SZ属大盘价值消费股，趋势惯性极强。忌用单一左侧超卖/超买逆势抄底逃顶，右侧结构破位权重应显著高于左侧指标共振。"
    },
    "002352.SZ": {
      "symbol_specific_notes": "002352.SZ属大盘/价值/基础设施，趋势惯性极强。右侧结构破位权重绝对优先于左侧枯竭；下降趋势中的反弹多为LPSY，未见绝对结构反转前只做顺势。"
    },
    "000792.SZ": {
      "symbol_specific_notes": "000792.SZ高波动属性，易现超买超卖钝化。结构破位（JOC/AS）权重需绝对优先于左侧极值（OB/OS），切勿滥用UTAD/Spring臆断；支撑阻力需预留1.5倍ATR容错。"
    },
    "600436.SH": {
      "symbol_specific_notes": "600436中盘成长股极易深幅洗盘。左侧枯竭绝不可豁免右侧SOS/SOW确认，严禁用OS/OB逆势否定带量结构破位，破位优先视为趋势加速。"
    },
    "000425.SZ": {
      "symbol_specific_notes": "000425.SZ 大盘价值制造股，趋势延续性极强。警惕将上涨中继误判为UTAD，未破关键支撑前倾向顺势；低位极端枯竭时严禁高置信度做空。逻辑推导明确时严禁退缩Neutral。"
    },
    "601100.SH": {
      "symbol_specific_notes": "601100.SH：大盘制造股。顶部OB_up+3H须视为UTAD高危预警，严禁美化成动能加速；底部OS_down+3L须视为Spring反转，严禁强判LPSY诱多。左侧极值客观事实权重绝对高于破位惯性预期。"
    },
    "600176.SH": {
      "symbol_specific_notes": "600176.SH：大盘价值制造股，趋势惯性极强。明确的结构破位（JOC/ASY/BOI/AS）具有绝对方向优先权，纯左侧枯竭共振不得豁免右侧确认，严禁用OB_up/OS_down极值逆势臆断UTAD/Spring。"
    },
    "688111.SH": {
      "symbol_specific_notes": "688111.SH：科技成长股，趋势延续性极强。右侧结构破位（JOC/BOI）的有效性极高，当破位未被证伪时，建议优先跟随破位方向，左侧枯竭共振仅建议作为降低顺势置信度的依据，不建议据此臆断UTAD/Spring陷阱。"
    },
    "601398.SH": {
      "symbol_specific_notes": "601100.SH：大盘价值制造股，极端枯竭后反转爆发力极强。当出现SOT+3H+OB_up或SOT+3L+OS_down极端共振时，供需枯竭事实权重必须高于趋势惯性预期，切勿强行美化为动能加速或下跌中继。"
