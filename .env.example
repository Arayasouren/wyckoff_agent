# ── LLM provider ──────────────────────────────────────────────────────────
# Default: Anthropic. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
FINAGENT_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=                 # optional proxy / self-hosted gateway

# Alternative: any OpenAI-compatible endpoint (GLM/智谱, DeepSeek, SiliconFlow, vLLM, ...)
# LLM_PROVIDER=openai
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_BASE_URL=https://api.your-provider.com/v1
# FINAGENT_MODEL=deepseek-chat

# Example — GLM / 智谱 (BigModel), OpenAI-compatible endpoint:
# LLM_PROVIDER=openai
# OPENAI_COMPAT_API_KEY=your-glm-api-key
# OPENAI_COMPAT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# FINAGENT_MODEL=glm-4.6

# Optional fallback endpoint — used only after the primary fails all retries.
# OPENAI_COMPAT_FALLBACK_API_KEY=
# OPENAI_COMPAT_FALLBACK_BASE_URL=
# FINAGENT_FALLBACK_MODEL=

# ── Embedding endpoint (OPTIONAL, independent of the LLM above) ───────────
# Powers memory "housekeeping" / entropy management only: note compression,
# dedup, and prompt-absorption. Leave it unset and the agent still runs fine —
# those housekeeping steps are just skipped (or fall back to LLM-only).
# It is a SEPARATE service from the LLM (e.g. SiliconFlow bge-m3); set it
# explicitly if you want housekeeping enabled.
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIM=1024

# ── Wyckoff computation service (REQUIRED) ────────────────────────────────
# Set the service URL and your authorization code (issued by the operator).
WYCKOFF_API_URL=https://wyckoff.example.com
WYCKOFF_API_KEY=your-authorization-code
# WYCKOFF_API_TIMEOUT=60
