# ── LLM provider ──────────────────────────────────────────────────────────
# Default: Anthropic. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
FINAGENT_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=                 # optional proxy / self-hosted gateway

# Alternative: any OpenAI-compatible endpoint (GLM/智谱, DeepSeek, SiliconFlow, vLLM, ...)
# LLM_PROVIDER=openai
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_BASE_URL=https://api.your-provider.com/v1
# FINAGENT_MODEL=deepseek-chat

# Example — GLM / 智谱 (BigModel), OpenAI-compatible endpoint:
# LLM_PROVIDER=openai
# OPENAI_COMPAT_API_KEY=your-glm-api-key
# OPENAI_COMPAT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# FINAGENT_MODEL=glm-4.6

# Optional fallback endpoint — used only after the primary fails all retries.
# OPENAI_COMPAT_FALLBACK_API_KEY=
# OPENAI_COMPAT_FALLBACK_BASE_URL=
# FINAGENT_FALLBACK_MODEL=

# ── Embeddings (memory semantic retrieval; optional) ──────────────────────
# Used as a fallback when LLM-based memory selection is unavailable.
# Falls back to the OPENAI_COMPAT_* values above if left unset.
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIM=1024

# ── Market data source ────────────────────────────────────────────────────
# akshare  — free A-share data (recommended for CN markets)
# yfinance — free global fallback
# wind     — Wind WDS (Oracle), licensed commercial data (see below)
DATA_SOURCE=akshare

# ── Wind WDS (Oracle) — OPTIONAL, licensed commercial service ─────────────
# Left blank on purpose. Fill in only if you have your own Wind account,
# then set DATA_SOURCE=wind. Requires the `oracledb` package.
# WIND_HOST=
# WIND_PORT=1521
# WIND_SERVICE=
# WIND_USER=
# WIND_PASSWORD=
# WIND_TABLE=winddb.ashareeodprices
# ORACLE_CLIENT_DIR=                  # path to Oracle Instant Client (thick mode), if needed

# ── Charts (off by default) ───────────────────────────────────────────────
# Set to 1 to render K-line evolution charts (requires matplotlib).
# FINAGENT_ENABLE_CHART=0

# ── Wyckoff kernel path ───────────────────────────────────────────────────
# The `wyckoff_analyzer` kernel is bundled at the repo root by default.
# Only set this if you relocate it.
# WYCKOFF_PATH=
